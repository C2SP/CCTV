+package mldsa
+
+import (
+	"crypto/rand"
+	"fmt"
+	"testing"
+)
+
+func TestSample(t *testing.T) {
+	t.Run("ML-DSA-44", func(t *testing.T) {
+		testSample(t, NewPrivateKey44)
+	})
+	t.Run("ML-DSA-65", func(t *testing.T) {
+		testSample(t, NewPrivateKey65)
+	})
+	t.Run("ML-DSA-87", func(t *testing.T) {
+		testSample(t, NewPrivateKey87)
+	})
+}
+
+func testSample(t *testing.T, keyGen func([]byte) (*PrivateKey, error)) {
+	testingOnlyRejectionReason = func(reason string) {
+		fmt.Printf("rejection: %s\n", reason)
+	}
+	t.Cleanup(func() {
+		testingOnlyRejectionReason = nil
+	})
+	seed := make([]byte, 32)
+	priv, err := keyGen(seed)
+	if err != nil {
+		t.Fatalf("keyGen: %v", err)
+	}
+	message := rand.Text()
+	fmt.Printf("seed: %s\n", message)
+	SignDeterministic(priv, []byte(message), "")
+}
